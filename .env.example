# --- Required ---
BOT_TOKEN=replace-me
DATABASE_URL=postgresql+asyncpg://timetrack:timetrack@localhost:5432/timetrack
OWNER_TG_ID=0

# --- Common ---
LOG_LEVEL=INFO
TIMEZONE=Europe/Warsaw

# --- Scheduler (Phase 1.1) ---
# MAX_SHIFT_HOURS=12
# REMINDER_AFTER_HOURS=10
# SCHEDULER_INTERVAL_SECONDS=300
# MAX_BREAK_HOURS=4

# --- Daily/weekly/monthly digest hour (Phase 2.x) ---
# DAILY_DIGEST_HOUR=22

# --- Photo archive in Supabase Storage (Phase 1.2) ---
# Empty values disable photo archival (only Telegram file_id is kept).
# SUPABASE_URL=https://xxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_STORAGE_BUCKET=shift-photos

# --- FastAPI admin panel (Phase 1A) ---
# Empty ADMIN_PASSWORD disables the panel (returns 503).
# ADMIN_USERNAME=owner
# ADMIN_PASSWORD=
# ADMIN_HOST=0.0.0.0
# ADMIN_PORT=8000

# --- Telegram webhook mode (Phase 1B) ---
# Both WEBHOOK_URL and WEBHOOK_SECRET must be set to switch from polling
# to webhook. WEBHOOK_URL is the public base URL (e.g. https://app.up.railway.app).
# WEBHOOK_PATH defaults to /tg/webhook and is appended automatically.
# WEBHOOK_URL=
# WEBHOOK_SECRET=
# WEBHOOK_PATH=/tg/webhook

# --- OpenAI Whisper voice transcription (Phase 2B) ---
# Empty OPENAI_API_KEY disables voice notes.
# OPENAI_API_KEY=
# WHISPER_MODEL=whisper-1
# WHISPER_LANGUAGE=ru
